# LLM API Keys (use Wrangler secrets in production)
VISION_LLM_API_KEY=your_vision_api_key_here
RESEARCH_LLM_API_KEY=your_research_api_key_here

# LLM Model Selection
VISION_LLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
RESEARCH_LLM_MODEL=google/gemma-4-31b-it

# LLM Endpoints (OpenAI-compatible chat completions API)
VISION_LLM_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
RESEARCH_LLM_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions

# Discogs API (https://www.discogs.com/developers/)
DISCOGS_CONSUMER_KEY=your_consumer_key_here
DISCOGS_CONSUMER_SECRET=your_consumer_secret_here

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173
