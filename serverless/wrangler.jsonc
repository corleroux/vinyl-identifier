{
  "name": "vinyl-identifier",
  "compatibility_date": "2026-06-08",
  "main": "src/index.ts",
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "env": {
    "staging": {
      "name": "vinyl-identifier-staging",
      "workers_dev": true,
      "vars": {
        "LLM_PROVIDER": "openai-compat",
        "LLM_FALLBACK_PROVIDER": "gemini",
        "GEMINI_ENDPOINT": "https://generativelanguage.googleapis.com/v1beta",
        "GEMINI_MODEL": "gemini-2.0-flash",
        "OPENAI_COMPAT_ENDPOINT": "https://integrate.api.nvidia.com/v1/chat/completions",
        "OPENAI_COMPAT_MODEL": "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning",
        "ALLOWED_ORIGINS": "http://localhost:5173,https://localhost,capacitor://localhost"
      }
    }
  }
}
